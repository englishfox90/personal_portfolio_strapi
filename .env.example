# Server Configuration
HOST=0.0.0.0
PORT=1337
URL=https://api.pfrastro.com

# Admin JWT Secret
ADMIN_JWT_SECRET=your-admin-jwt-secret

# API Token Salt
API_TOKEN_SALT=your-api-token-salt

# App Keys (comma-separated)
APP_KEYS=your-app-key-1,your-app-key-2,your-app-key-3,your-app-key-4

# JWT Secret
JWT_SECRET=your-jwt-secret

# Database Configuration
DATABASE_CLIENT=postgres
DATABASE_HOST=your-database-host
DATABASE_PORT=5432
DATABASE_NAME=railway
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-database-password
DATABASE_SSL=false

# Upload Provider Configuration
UPLOAD_PROVIDER=aws-s3

# Railway S3-Compatible Storage (PRIVATE bucket - access is via signed URLs only)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_DEFAULT_REGION=auto
AWS_S3_BUCKET_NAME=your_bucket_name
AWS_ENDPOINT_URL=https://storage.railway.app
# Signed URL lifetime in seconds (default: 7 days)
AWS_SIGNED_URL_EXPIRES=604800

# CORS - comma-separated list of allowed origins for cross-origin API requests
CORS_ORIGINS=https://www.pfrastro.com,https://pfrastro.com,http://localhost:3000

# Rate limiting for public endpoints (per-IP sliding window, in-memory)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_COMMENTS_MAX=10
RATE_LIMIT_COUNTERS_MAX=30
RATE_LIMIT_SIGNED_URL_MAX=60
